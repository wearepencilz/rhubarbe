# Shopify Configuration (Janine Ice Cream Shop)
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=janinemtl.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-storefront-access-token

# Shopify Admin API Access - Choose ONE of the following methods:

# METHOD 1: OAuth App (Client Credentials Flow)
# Use this if you have a Shopify OAuth app with client ID and secret
SHOPIFY_CLIENT_ID=your-client-id
SHOPIFY_CLIENT_SECRET=your-client-secret

# METHOD 2: Custom App (Direct Access Token)
# Use this if you created a custom app in Shopify Admin
# SHOPIFY_ADMIN_ACCESS_TOKEN=shpat-your-admin-access-token

# Note: The system will automatically use OAuth if CLIENT_ID and CLIENT_SECRET are provided,
# otherwise it will use the direct ADMIN_ACCESS_TOKEN

# NextAuth (CMS Authentication)
AUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=same-as-auth-secret

# Vercel KV (Production Data Storage)
# These are automatically added when you connect Vercel KV
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Vercel Blob (Production Image Storage)
# REQUIRED FOR PRODUCTION: Images uploaded through the CMS will be stored here
# 
# Setup Instructions:
# 1. Go to Vercel Dashboard → Your Project → Storage
# 2. Click "Create Database" → Select "Blob" → Click "Connect to Project"
# 3. Vercel automatically adds this variable to your environment
# 4. Images are served via CDN: https://[random].public.blob.vercel-storage.com/[filename]
#
# Local Development: Leave empty - uploads will use public/uploads/ directory
# Production: Automatically set by Vercel when you connect Blob Storage
#
# Format: vercel_blob_rw_XXXXXXXXXX_YYYYYYYYYYYYYYYYYYYYYYYYYYYY
BLOB_READ_WRITE_TOKEN=

# Optional: Custom Redis (if not using Vercel KV)
# REDIS_URL=redis://user:password@host:port

# PostgreSQL Database (for game feature)
# Required for pixel art game leaderboards, rewards, and analytics
# 
# Setup Instructions:
# 1. Create a PostgreSQL database (Vercel Postgres, Neon, Supabase, or local)
# 2. Add the connection string below
# 3. Run migration: npx tsx lib/game/migrations/run-migration.ts
#
# Format: postgresql://user:password@host:port/database
# Vercel Postgres: Automatically set when you connect Vercel Postgres
DATABASE_URL=
# Alternative name (some providers use this)
POSTGRES_URL=

# Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# AI Autofill (optional)
# Used for AI-assisted ingredient form completion
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
